<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <base href="/stager/"/>
    <title>ChattyStager</title>
    <ResourcePreloader/>
    <link rel="stylesheet" href="css/tailwind.css" />
    <link rel="stylesheet" href="@Assets["ChattyStager.styles.css"]"/>
    <ImportMap/>
    <link rel="icon" type="image/png" href="favicon.png"/>
    <HeadOutlet/>
</head>
 
<body class="w-full min-h-screen">
<Routes/>
<ReconnectModal/>
<script src="@Assets["_framework/blazor.web.js"]"></script>
<script>
(function () {
    // --- Navigation progress bar ---
    const bar = document.querySelector('.navigation-progress');
    if (bar) {
        const navContainer = document.querySelector('aside.p-4');
        if (navContainer) {
            navContainer.addEventListener('click', function (e) {
                const link = e.target.closest('a');
                if (link && bar) {
                    bar.classList.remove('navigation-progress--done');
                }
            });
        }
    }

    window.hideNavigationProgress = function () {
        if (bar) bar.classList.add('navigation-progress--done');
    };

    // --- Scroll helper ---
    window.scrollElementToBottom = function (el) {
        if (el) el.scrollTop = el.scrollHeight;
    };
})();
</script>
</body>

</html>