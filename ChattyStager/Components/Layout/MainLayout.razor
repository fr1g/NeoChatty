@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="grid grid-cols-4 gap-3 w-full min-h-screen bg-slate-50/50 p-3">
    @if (!isInSetupRoute)
    {
        <div class="w-full bg-slate-100 shadow">
            
        </div>
    }
    
    <div id="main-renderer" class="w-full bg-slate-100 shadow @(isInSetupRoute ? "col-span-4" : "col-span-3")">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool isInSetupRoute;
    protected override void OnInitialized()
    {
        isInSetupRoute = NavigationManager.Uri.Contains("/Setup");
    }
}

<style>
    #blazor-error-ui {
        color-scheme: light only;
        background: lightyellow;
        bottom: 0;
        box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.2);
        box-sizing: border-box;
        display: none;
        left: 0;
        padding: 0.6rem 1.25rem 0.7rem 1.25rem;
        position: fixed;
        width: 100%;
        z-index: 1000;
    }

    #blazor-error-ui .dismiss {
        cursor: pointer;
        position: absolute;
        right: 0.75rem;
        top: 0.5rem;
    }
</style>
