@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<div class="navigation-progress navigation-progress--done"></div>

<div class="grid grid-cols-1 gap-3 w-full min-h-screen bg-slate-50 p-3 lg:grid-cols-5">
    @if (!isInSetupRoute)
    {
        <div class="w-full rounded-lg bg-slate-900 text-white shadow lg:col-span-1">
            <NavMenu />
        </div>
    }
    
    <div id="main-renderer" class="w-full rounded-lg bg-white shadow @(isInSetupRoute ? "lg:col-span-5" : "lg:col-span-4")">
        @Body
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="Dashboard" class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code
{
    private bool isInSetupRoute;

    protected override void OnInitialized()
    {
        isInSetupRoute = NavigationManager.Uri.Contains("/Setup");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        isInSetupRoute = NavigationManager.Uri.Contains("/Setup");
        if (!firstRender)
            await Task.Delay(300);
        await JS.InvokeVoidAsync("hideNavigationProgress");
    }
}

<style>
    .navigation-progress {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 3px;
        z-index: 9999;
        pointer-events: none;
        background: transparent;
    }

    .navigation-progress:not(.navigation-progress--done)::after {
        content: '';
        display: block;
        height: 100%;
        width: 40%;
        background: linear-gradient(90deg, #3b82f6, #6366f1);
        animation: nav-progress-slide 1.2s ease-in-out infinite;
    }

    .navigation-progress--done::after {
        content: '';
        display: block;
        height: 100%;
        width: 100%;
        background: #22c55e;
        animation: nav-progress-complete 0.4s ease-out forwards;
        opacity: 0;
    }

    @@keyframes nav-progress-slide {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(350%); }
    }

    @@keyframes nav-progress-complete {
        0% { opacity: 1; }
        100% { opacity: 0; }
    }

    #blazor-error-ui {
        color-scheme: light only;
        background: lightyellow;
        bottom: 0;
        box-shadow: 0 -1px 2px rgba(0, 0, 0, 0.2);
        box-sizing: border-box;
        display: none;
        left: 0;
        padding: 0.6rem 1.25rem 0.7rem 1.25rem;
        position: fixed;
        width: 100%;
        z-index: 1000;
    }

    #blazor-error-ui .dismiss {
        cursor: pointer;
        position: absolute;
        right: 0.75rem;
        top: 0.5rem;
    }
</style>
