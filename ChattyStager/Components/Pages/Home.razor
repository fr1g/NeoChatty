@page "/"
@implements IDisposable
@using ChattyStager.Services
@using ChattyStager.Model
@using System.Text.Json
@inject StagerConfig Config
@inject SessionService SessionService
@inject SessionStateProvider SessionState
@inject DashboardService Dashboard
@inject BackendProcessService BackendProc
@inject NavigationManager Navigation

<PageTitle>Dashboard - ChattyStager</PageTitle>

<div class="max-w-7xl mx-auto grid grid-cols-1 gap-8 py-5">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Dashboard</h1>
            <p class="text-gray-500 text-sm">@DateTime.Now.ToString("yyyy-MM-dd HH:mm:ss")</p>
        </div>
        <div class="flex gap-2">
            <button class="px-3 py-1.5 bg-indigo-100 text-indigo-700 rounded-lg text-sm hover:bg-indigo-200" @onclick="RefreshDashboard">
                🔄 Refresh
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
            <p class="text-gray-500 text-sm">New Users (24h)</p>
            <p class="text-3xl font-bold text-gray-800 mt-1">@DashboardData.UsersLast24h</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
            <p class="text-gray-500 text-sm">Total Users</p>
            <p class="text-3xl font-bold text-gray-800 mt-1">@DashboardData.TotalUsers</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
            <p class="text-gray-500 text-sm">Messages (24h)</p>
            <p class="text-3xl font-bold text-gray-800 mt-1">@DashboardData.MessagesLast24h</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm p-5 border border-gray-100">
            <p class="text-gray-500 text-sm">Logins (24h)</p>
            <p class="text-3xl font-bold text-gray-800 mt-1">@DashboardData.LoginsLast24h</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">System Resources</h2>
            <div class="space-y-4">
                <div>
                    <div class="flex justify-between text-sm mb-1">
                        <span class="text-gray-600">Memory Usage</span>
                        <span class="text-gray-800 font-medium">@DashboardData.MemoryUsageMB MB / @DashboardData.TotalMemoryMB MB</span>
                    </div>
                    <div class="w-full bg-gray-200 rounded-full h-2.5">
                        <div class="bg-indigo-600 h-2.5 rounded-full" style="width: @GetMemoryPercent()%"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Server Info</h2>
            <div class="space-y-2 text-sm">
                <div class="flex justify-between">
                    <span class="text-gray-500">Web Frontend</span>
                    <span class="text-gray-800">@(!string.IsNullOrEmpty(Config.ChattyWebEndpoint) ? Config.ChattyWebEndpoint : "Not configured")</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">Hostname</span>
                    <span class="text-gray-800">@(!string.IsNullOrEmpty(Config.ChattyHostName) ? Config.ChattyHostName : "Not configured")</span>
                </div>
                <div class="flex justify-between">
                    <span class="text-gray-500">Database</span>
                    <span class="text-gray-800">@Config.MySqlAddr:@Config.MySqlPort</span>
                </div>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100 ">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Backend Process</h2>
        <div class="space-y-4">
            <div class="flex items-center gap-3">
                <span class="inline-block w-3 h-3 rounded-full @(BackendProc.IsRunning ? "bg-green-500" : "bg-gray-400")"></span>
                <span class="text-gray-700">@(BackendProc.IsRunning ? "Running" : "Stopped")</span>
            </div>
            <div class="flex gap-2">
                <button class="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 disabled:opacity-50 text-sm"
                        disabled="@(BackendProc.IsRunning || IsStarting)" @onclick="StartBackend">
                    @(IsStarting ? "Starting..." : "Start")
                </button>
                <button class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 disabled:opacity-50 text-sm"
                        disabled="@(!BackendProc.IsRunning || IsStopping)" @onclick="StopBackend">
                    @(IsStopping ? "Stopping..." : "Stop")
                </button>
            </div>
            @if (!string.IsNullOrEmpty(BackendMessage))
            {
                <div class="@(BackendMessage.Contains("Error") ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800") p-3 rounded-lg text-sm">
                    @BackendMessage
                </div>
            }
            @if (BackendProc.IsRunning && !string.IsNullOrEmpty(BackendOutput))
            {
                <div class="mt-4">
                    <h3 class="text-sm font-medium text-gray-700 mb-2">Real-time Output</h3>
                    <pre class="bg-gray-900 text-green-400 p-4 rounded-lg text-xs max-h-64 overflow-y-auto">@BackendOutput</pre>
                </div>
            }
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Quick Actions</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
            <a href="/stager/Settings" class="block p-4 bg-gray-50 rounded-lg hover:bg-gray-100 text-center">
                <div class="text-2xl mb-1">⚙️</div>
                <div class="text-sm text-gray-700">Settings</div>
            </a>
            <a href="/stager/ManageUsers" class="block p-4 bg-gray-50 rounded-lg hover:bg-gray-100 text-center">
                <div class="text-2xl mb-1">👥</div>
                <div class="text-sm text-gray-700">Users</div>
            </a>
            <a href="/stager/Database" class="block p-4 bg-gray-50 rounded-lg hover:bg-gray-100 text-center">
                <div class="text-2xl mb-1">🗄️</div>
                <div class="text-sm text-gray-700">Database</div>
            </a>
            <button class="p-4 bg-gray-50 rounded-lg hover:bg-gray-100 text-center" @onclick="OpenWebApp">
                <div class="text-2xl mb-1">🌐</div>
                <div class="text-sm text-gray-700">Open Web App</div>
            </button>
        </div>
    </div>
    <div class="bg-white rounded-xl shadow-sm p-6 border border-gray-100">
        debug-info::
                        @($"isSetUp:{Config.IsSetUp}");
        
    </div>
</div>

@code {
    private DashboardData DashboardData = new();
    private string BackendMessage = "";
    private string BackendOutput = "";
    private bool IsStarting = false;
    private bool IsStopping = false;
    private Timer? RefreshTimer;

    protected override async Task OnInitializedAsync()
    {
        if (!SessionService.IsAuthenticated(SessionState.CircuitId))
        {
            Navigation.NavigateTo("/Login");
            return;
        }
        await RefreshDashboard();
        RefreshTimer = new Timer(async _ =>
        {
            var data = await Dashboard.GetDataAsync();
            var output = BackendProc.GetOutput();
            await InvokeAsync(() =>
            {
                DashboardData = data;
                if (output != null) BackendOutput = output;
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    private async Task RefreshDashboard()
    {
        DashboardData = await Dashboard.GetDataAsync();
        BackendOutput = BackendProc.GetOutput() ?? "";
    }

    private async Task StartBackend()
    {
        IsStarting = true;
        BackendMessage = "";
        var result = await BackendProc.StartAsync();
        BackendMessage = result.message;
        IsStarting = false;
    }

    private async Task StopBackend()
    {
        IsStopping = true;
        BackendMessage = "";
        var result = await BackendProc.StopAsync();
        BackendMessage = result.message;
        IsStopping = false;
    }

    private double GetMemoryPercent()
    {
        if (DashboardData.TotalMemoryMB > 0)
            return Math.Round(DashboardData.MemoryUsageMB / DashboardData.TotalMemoryMB * 100, 1);
        return 0;
    }

    private void OpenWebApp()
    {
        if (!string.IsNullOrEmpty(Config.ChattyWebEndpoint))
            Navigation.NavigateTo(Config.ChattyWebEndpoint);
    }

    public void Dispose()
    {
        RefreshTimer?.Dispose();
    }
}
