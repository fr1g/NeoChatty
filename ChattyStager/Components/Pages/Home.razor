@page "/"
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject StagerConfigService ConfigService
@inject DashboardMetricsService DashboardMetrics

@using ChattyStager.Components.Parts
<PageTitle>Dashboard</PageTitle>

<main class="p-6 space-y-6">
    <header class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="text-3xl font-semibold text-slate-950">ChattyStager Dashboard</h1>
            <p class="text-slate-500">System, database, and managed backend status.</p>
        </div>
        <div class="space-x-3">
            <Button UsePresetClass="false" Mode="@Button.ButtonMode.Anchor" class="btn-danger" Href="./Lock" Target="_self">
                Lock Session
            </Button>
            <button type="button" class="btn-primary" @onclick="LoadDashboardAsync" disabled="@loading">
                @(loading ? "Refreshing..." : "Refresh")
            </button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <p class="alert-error" role="alert">@error</p>
    }

    @if (snapshot == null)
    {
        <section class="panel">
            <p class="text-slate-500">Loading dashboard...</p>
        </section>
    }
    else
    {
        @if (!snapshot.DatabaseOk)
        {
            <p class="alert-error" role="alert">Database metrics unavailable: @snapshot.DatabaseMessage</p>
        }

        <section class="grid grid-cols-1 gap-4 lg:grid-cols-4">
            <article class="metric">
                <span>Backend</span>
                <strong>@(snapshot.Backend.IsRunning ? "Running" : "Stopped")</strong>
                <small>@snapshot.Backend.Message</small>
            </article>
            <article class="metric">
                <span>Messages / 24h</span>
                <strong>@(snapshot.DatabaseOk ? snapshot.MessagesLast24Hours.ToString() : "N/A")</strong>
                <small>Rows created in messages</small>
            </article>
            <article class="metric">
                <span>Registered Users</span>
                <strong>@(snapshot.DatabaseOk ? snapshot.RegisteredUsers.ToString() : "N/A")</strong>
                <small>Total rows in users</small>
            </article>
            <article class="metric">
                <span>CPU</span>
                <strong>@snapshot.CpuPercent.ToString("0.0")%</strong>
                <small>Stager process sample</small>
            </article>
        </section>

        <section class="grid grid-cols-1 gap-4 lg:grid-cols-2">
            <article class="panel">
                <h2 class="section-title">Memory</h2>
                <p class="metric-line">@snapshot.MemoryUsedMb.ToString("0") MB / @snapshot.MemoryTotalMb.ToString("0") MB</p>
                <progress class="w-full accent-blue-600" value="@snapshot.MemoryUsedMb" max="@snapshot.MemoryTotalMb"></progress>
            </article>
            <article class="panel">
                <h2 class="section-title">Disk</h2>
                <p class="metric-line">@snapshot.DiskUsedGb.ToString("0.0") GB / @snapshot.DiskTotalGb.ToString("0.0") GB</p>
                <progress class="w-full accent-blue-600" value="@snapshot.DiskUsedGb" max="@snapshot.DiskTotalGb"></progress>
            </article>
        </section>

        <section class="panel">
            <h2 class="section-title">Backend Runtime</h2>
            <dl class="mt-4 grid grid-cols-1 gap-3 text-sm md:grid-cols-2">
                <div>
                    <dt class="text-slate-500">Health URL</dt>
                    <dd class="font-mono text-slate-950">@snapshot.Backend.HealthUrl</dd>
                </div>
                <div>
                    <dt class="text-slate-500">PID</dt>
                    <dd class="font-mono text-slate-950">@(snapshot.Backend.ProcessId?.ToString() ?? "N/A")</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Log path</dt>
                    <dd class="font-mono text-slate-950 break-all">@snapshot.Backend.LogPath</dd>
                </div>
                <div>
                    <dt class="text-slate-500">Health check</dt>
                    <dd class="font-semibold @(snapshot.Backend.HealthOk ? "text-green-700" : "text-red-700")">@(snapshot.Backend.HealthOk ? "OK" : "Failed")</dd>
                </div>
            </dl>
        </section>

        <p class="text-sm text-slate-500">Updated at @snapshot.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</p>
    }
</main>

@code {
    private StagerConfig? config;
    private DashboardSnapshot? snapshot;
    private string error = "";
    private bool loading;

    protected override async Task OnInitializedAsync()
    {
        config = await ConfigService.LoadAsync();
        if (!config.IsSetUp)
        {
            NavigationManager.NavigateTo("/stager/Setup");
            return;
        }

        await LoadDashboardAsync();
    }

    private async Task LoadDashboardAsync()
    {
        if (config == null)
            return;

        loading = true;
        error = "";
        try
        {
            snapshot = await DashboardMetrics.GetSnapshotAsync(config);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            loading = false;
        }
    }
}
