@page "/Login"
@using ChattyStager.Services
@using ChattyStager.Model
@inject StagerConfig Config
@inject SessionService SessionService
@inject SessionStateProvider SessionState
@inject NavigationManager Navigation

<PageTitle>Login - ChattyStager</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-indigo-900 via-blue-900 to-slate-900 flex items-center justify-center p-4">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-md p-8">
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-gray-800">ChattyStager</h1>
            <p class="text-gray-500 text-sm">Enter the access password to continue</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="bg-red-100 text-red-800 p-3 rounded-lg mb-4">@ErrorMessage</div>
        }

        <div class="space-y-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Access Password</label>
                <input type="password" @bind="PassKeyInput" @onkeydown="HandleKeyDown"
                       class="w-full p-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500"
                       placeholder="Enter password" />
            </div>
            <button class="w-full py-2.5 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 font-medium disabled:opacity-50"
                    disabled="@(string.IsNullOrEmpty(PassKeyInput))" @onclick="DoLogin">
                Login
            </button>
        </div>
    </div>
</div>

@code {
    private string PassKeyInput = "";
    private string ErrorMessage = "";

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await DoLogin();
    }

    private async Task DoLogin()
    {
        ErrorMessage = "";
        var circuitId = SessionState.CircuitId;
        if (SessionService.Authenticate(circuitId, PassKeyInput))
        {
            Navigation.NavigateTo("/");
        }
        else
        {
            ErrorMessage = "Incorrect password. Please try again.";
        }
    }
}
