@page "/Setup"
@rendermode InteractiveServer

@inject NavigationManager NavigationManager
@inject StagerConfigService ConfigService
@inject SystemInspectionService InspectionService
@inject ArtifactDeploymentService ArtifactDeployment
@inject DatabaseSetupService DatabaseSetup

<PageTitle>Setup</PageTitle>

<main class="min-h-screen bg-slate-50 p-6">
    <div class="mx-auto flex min-h-[calc(100vh-3rem)] max-w-6xl flex-col gap-5">
        <header>
            <h1 class="text-3xl font-semibold text-slate-950">ChattyStager Setup</h1>
            <p class="text-slate-500">Check runtime, initialize database, deploy GitHub Actions artifacts, and write backend config.</p>
        </header>

        <nav aria-label="Progress" class="rounded-md bg-white p-3 shadow-sm">
            <ol class="grid grid-cols-2 gap-2 text-sm md:grid-cols-5">
                @foreach (var item in steps.Select((label, index) => (label, index)))
                {
                    <li class="rounded px-3 py-2 @(Step == item.index ? "bg-blue-600 text-white" : item.index < Step ? "bg-blue-50 text-blue-700" : "bg-slate-100 text-slate-500")">
                        @(item.index + 1). @item.label
                    </li>
                }
            </ol>
        </nav>

        @if (!string.IsNullOrWhiteSpace(status))
        {
            <p class="alert-info" role="status">@status</p>
        }
        @if (!string.IsNullOrWhiteSpace(error))
        {
            <p class="alert-error" role="alert">@error</p>
        }

        <section class="panel grow">
            @RenderStep()
        </section>

        <footer class="flex justify-between">
            <button type="button" class="btn-secondary" @onclick="PrevStep" disabled="@(Step == 0 || busy)">Previous</button>
            <button type="button" class="btn-primary" @onclick="NextStep" disabled="@(!CanMoveNext || busy)">@(Step == steps.Length - 1 ? "Open Dashboard" : "Next")</button>
        </footer>
    </div>
</main>

@code {
    private readonly string[] steps = ["Runtime", "Database", "Artifacts", "Backend Config", "Finish"];
    private StagerConfig config = new();
    private RuntimeCheckResult? runtime;
    private DeploymentResult? databaseResult;
    private DeploymentResult? backendDeployResult;
    private DeploymentResult? webDeployResult;
    private int Step;
    private bool busy;
    private string status = "";
    private string error = "";
    private string sqlPath = "";

    private bool CanMoveNext => Step switch
    {
        0 => runtime?.IsReady == true,
        1 => databaseResult?.Success == true,
        2 => backendDeployResult?.Success == true && webDeployResult?.Success == true,
        _ => true,
    };

    protected override async Task OnInitializedAsync()
    {
        config = await ConfigService.LoadAsync();
        sqlPath = ResolveInitSqlPath();
        await RunChecksAsync();
    }

    private RenderFragment RenderStep()
    {
        return Step switch
        {
            0 => @<div class="space-y-5">
                <div>
                    <h2 class="section-title">Runtime Checks</h2>
                    <p class="text-sm text-slate-500">Node.js 22 or newer and a supported database client must pass before setup. Database connection is tested during initialization.</p>
                </div>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                    @RenderRuntimeItem(runtime?.Node)
                    @RenderRuntimeItem(runtime?.DatabaseClient)
                </div>
                <button type="button" class="btn-secondary" @onclick="RunChecksAsync" disabled="@busy">Run Checks</button>
            </div>,
            1 => @<EditForm Model="config" OnValidSubmit="InitializeDatabaseAsync" class="space-y-5">
                <DataAnnotationsValidator />
                <h2 class="section-title">Database Initialization</h2>
                <div class="form-grid">
                    <label>
                        <span>Host</span>
                        <InputText name="mysqlHost" class="form-input" @bind-Value="config.MySqlAddr" />
                    </label>
                    <label>
                        <span>Port</span>
                        <InputNumber name="mysqlPort" class="form-input" @bind-Value="config.MySqlPort" />
                    </label>
                    <label>
                        <span>Database</span>
                        <InputText name="mysqlDatabase" class="form-input" @bind-Value="config.MySqlDatabase" />
                    </label>
                    <label>
                        <span>User</span>
                        <InputText name="mysqlUser" class="form-input" @bind-Value="config.MySqlUser" />
                    </label>
                    <label>
                        <span>Password</span>
                        <InputText name="mysqlPassword" type="password" autocomplete="current-password" class="form-input" @bind-Value="config.MySqlPassword" />
                    </label>
                    <label>
                        <span>SQL init file</span>
                        <InputText name="sqlPath" class="form-input" @bind-Value="sqlPath" />
                    </label>
                </div>
                <button type="submit" class="btn-primary" disabled="@busy">Initialize and Validate Database</button>
                @RenderDeploymentResult(databaseResult)
            </EditForm>,
            2 => @<div class="space-y-5">
                <h2 class="section-title">GitHub Actions Artifacts</h2>
                <p class="text-sm text-slate-500">Downloads release assets from the latest public release at <code>@GitHubArtifactConstants.RepositoryReleasesUrl</code>.</p>
                <dl class="grid grid-cols-1 gap-3 rounded-md border border-slate-200 bg-slate-50 p-4 text-sm md:grid-cols-2">
                    <div>
                        <dt class="text-slate-500">Server artifact</dt>
                        <dd class="font-mono text-slate-950">@GitHubArtifactConstants.ServerArtifactName -> @config.BackendWorkingDirectory</dd>
                    </div>
                    <div>
                        <dt class="text-slate-500">Webapp artifact</dt>
                        <dd class="font-mono text-slate-950">@GitHubArtifactConstants.WebappArtifactName -> @ConfigService.GetWebDeployPath(config)</dd>
                    </div>
                </dl>
                <button type="button" class="btn-primary" @onclick="DeployArtifactsAsync" disabled="@busy">Download and Deploy Latest Build</button>
                <div class="grid grid-cols-1 gap-4 lg:grid-cols-2">
                    @RenderDeploymentResult(backendDeployResult)
                    @RenderDeploymentResult(webDeployResult)
                </div>
            </div>,
            3 => @<EditForm Model="config" OnValidSubmit="SaveBackendConfigAsync" class="space-y-5">
                <h2 class="section-title">Backend Config</h2>
                <div class="rounded-md border border-amber-200 bg-amber-50 p-3 text-sm text-amber-800" role="alert">
                    <strong>Warning:</strong> If you don&apos;t know what these are, do not change these settings.
                </div>
                <div class="form-grid">
                    <label>
                        <span>Backend executable</span>
                        <InputText name="backendExecutable" class="form-input" @bind-Value="config.BackendExecutable" />
                    </label>
                    <label>
                        <span>Backend arguments</span>
                        <InputText name="backendArguments" class="form-input" @bind-Value="config.BackendArguments" />
                    </label>
                    <label>
                        <span>Health URL</span>
                        <InputText name="healthUrl" class="form-input" @bind-Value="config.HealthUrl" />
                    </label>
                    <label>
                        <span>Server port</span>
                        <InputNumber name="serverPort" class="form-input" @bind-Value="config.ServerPort" />
                    </label>
                    <label>
                        <span>MOTD</span>
                        <InputText name="motd" class="form-input" @bind-Value="config.Motd" />
                    </label>
                    <label>
                        <span>Info</span>
                        <InputText name="info" class="form-input" @bind-Value="config.Info" />
                    </label>
                </div>
                <button type="submit" class="btn-primary" disabled="@busy">Write Backend Config</button>
            </EditForm>,
            _ => @<div class="space-y-5">
                <h2 class="section-title">Ready</h2>
                <p class="text-slate-600">Setup completed. Use Settings to start the backend and Manage Users to call ban/unban procedures.</p>
                <button type="button" class="btn-primary" @onclick="CompleteSetupAsync" disabled="@busy">Finish Setup</button>
            </div>,
        };
    }

    private RenderFragment RenderRuntimeItem(RuntimeCheckItem? item)
    {
        return @<article class="rounded-md border border-slate-200 bg-slate-50 p-4">
            <p class="text-sm text-slate-500">@(item?.Name ?? "Checking...")</p>
            <p class="mt-1 text-lg font-semibold text-slate-950 break-words">@(item?.Detected ?? "Not checked")</p>
            <p class="mt-2 text-sm @(item?.IsSupported == true ? "text-green-700" : "text-red-700")">@(item?.Message ?? "Run checks to inspect this host.")</p>
            <p class="mt-1 text-xs text-slate-500 break-all">Path: @(item?.Path ?? "-")</p>
            <p class="mt-1 text-xs text-slate-500">Required: @(item?.Required ?? "-")</p>
        </article>;
    }

    private RenderFragment RenderDeploymentResult(DeploymentResult? result)
    {
        return @<article class="mt-4 rounded-md border border-slate-200 bg-slate-50 p-4">
            @if (result == null)
            {
                <p class="text-sm text-slate-500">No operation has run yet.</p>
            }
            else
            {
                <p class="font-semibold @(result.Success ? "text-green-700" : "text-red-700")">@result.Message</p>
                <ol class="mt-3 space-y-2 text-sm">
                    @foreach (var step in result.Steps)
                    {
                        <li class="flex items-start justify-between gap-4 rounded bg-white px-3 py-2">
                            <span>@step.Name</span>
                            <span class="font-semibold @(step.State == OperationState.Success ? "text-green-700" : "text-red-700")">@step.State</span>
                        </li>
                    }
                </ol>
                <details class="mt-3">
                    <summary class="cursor-pointer text-sm font-medium text-slate-700">Logs</summary>
                    <pre class="mt-2 max-h-72 overflow-auto rounded bg-slate-950 p-3 text-xs text-slate-50" tabindex="0"><code>@string.Join(Environment.NewLine, result.Logs.Select(log => $"[{log.At:HH:mm:ss}] {log.Level}: {log.Message}"))</code></pre>
                </details>
            }
        </article>;
    }

    private async Task RunChecksAsync()
    {
        await ExecuteAsync(async () =>
        {
            ConfigService.ApplyDefaults(config);
            runtime = await InspectionService.CheckRuntimeAsync(config);
            status = runtime.IsReady ? "Runtime checks passed." : "Runtime checks need attention.";
        });
    }

    private async Task InitializeDatabaseAsync()
    {
        await ExecuteAsync(async () =>
        {
            await ConfigService.SaveAsync(config);
            databaseResult = await DatabaseSetup.InitializeDatabaseAsync(config, sqlPath);
            if (!databaseResult.Success)
                throw new InvalidOperationException(databaseResult.Message);
            status = databaseResult.Message;
        });
    }

    private async Task DeployArtifactsAsync()
    {
        await ExecuteAsync(async () =>
        {
            ConfigService.ApplyDefaults(config);
            await ConfigService.SaveAsync(config);
            var deployment = await ArtifactDeployment.DeployBuildArtifactsFromGitHubAsync(config);
            backendDeployResult = deployment.Backend;
            webDeployResult = deployment.Webapp;
            if (!backendDeployResult.Success)
                throw new InvalidOperationException(backendDeployResult.Message);
            if (!webDeployResult.Success)
                throw new InvalidOperationException(webDeployResult.Message);
            await ConfigService.SaveAsync(config);
            status = "Backend and web artifacts deployed.";
        });
    }

    private async Task SaveBackendConfigAsync()
    {
        await ExecuteAsync(async () =>
        {
            await ConfigService.SaveAsync(config);
            await ConfigService.WriteServerConfigAsync(config);
            status = $"Backend config written to {config.ServerConfigPath}.";
        });
    }

    private async Task CompleteSetupAsync()
    {
        await ExecuteAsync(async () =>
        {
            config.IsSetUp = true;
            await ConfigService.SaveAsync(config);
            NavigationManager.NavigateTo("/stager/");
        });
    }

    private void PrevStep()
    {
        Step = Math.Max(0, Step - 1);
        error = "";
    }

    private void NextStep()
    {
        if (Step == steps.Length - 1)
        {
            NavigationManager.NavigateTo("/stager/");
            return;
        }

        Step++;
        error = "";
    }

    private async Task ExecuteAsync(Func<Task> action)
    {
        busy = true;
        error = "";
        status = "";
        try
        {
            await action();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            busy = false;
        }
    }

    private static string ResolveInitSqlPath()
    {
        var candidates = new[]
        {
            Path.GetFullPath(Path.Combine(Directory.GetCurrentDirectory(), "..", "init.sql")),
            Path.GetFullPath(Path.Combine(AppContext.BaseDirectory, "..", "..", "..", "..", "init.sql")),
            Path.GetFullPath("init.sql"),
        };

        return candidates.FirstOrDefault(File.Exists) ?? candidates[0];
    }
}
