{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
  "Endpoints": {
    "Http": {
      "Url": "http://*:80"
    },
    "Https": {
      "Url": "https://*:443",
      "Certificate": {
        "Path": "certs/your_certificate.pfx",
        "Password": "your_password"
      }
    }
  }
},
  "AllowedHosts": "*"
}