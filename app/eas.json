{
    "cli": {
        "version": ">= 5.0.0",
        "promptToConfigurePushNotifications": false
    },
    "build": {
        "development": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "buildType": "simulator"
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "buildType": "archive"
            }
        },
        "production": {
            "distribution": "store",
            "android": {
                "buildType": "app-bundle"
            },
            "ios": {
                "buildType": "archive"
            }
        }
    },
    "submit": {
        "production": {}
    }
}